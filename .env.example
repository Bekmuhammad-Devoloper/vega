# Nusxa oling: cp .env.example .env  (yoki qo'lda .env yarating)

# Ma'lumotlar bazasi (SQLite)
DATABASE_URL="file:./dev.db"

# Sessiya maxfiy kaliti (kamida 32 belgi, tasodifiy)
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Provayderlar ---
# SPIDER TG API — real SIM, Telegram uchun ISHLAYDI (Telegram uchun BIRINCHI).
SPIDER_API_KEY=""
SPIDER_BASE_URL="https://api.spider-service.com"

# HeroSMS (SMS-Activate protokoli) — boshqa xizmatlar (Instagram/Google...) uchun arzon.
HEROSMS_API_KEY=""
HEROSMS_BASE_URL="https://hero-sms.com/stubs/handler_api.php"

# 5sim API kaliti (HeroSMS bo'sh bo'lsa ishlatiladi; ikkisi ham bo'sh = MOCK/demo)
FIVESIM_API_KEY=""
# 5sim bloklangan bo'lsa — mirror/proxy manzili
FIVESIM_BASE_URL="https://5sim.net/v1"

# Narx sozlamalari (5sim USD'da qaytaradi)
USD_TO_UZS="12000"
MARKUP_PERCENT="30"

# Ilova manzili (to'lov qaytish havolalari uchun)
APP_URL="http://localhost:3000"

# To'lov / balans to'ldirish
# DEMO to'ldirish sinov uchun darhol balans qo'shadi — PROD'da false qiling!
DEMO_TOPUP="true"
MIN_TOPUP="1000"
MAX_TOPUP="10000000"

# Payme (ixtiyoriy — to'ldirilsa yoqiladi)
PAYME_MERCHANT_ID=""
PAYME_KEY=""

# Click (ixtiyoriy — to'ldirilsa yoqiladi)
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
