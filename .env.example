# Nusxa oling: cp .env.example .env  (yoki qo'lda .env yarating)

# Ma'lumotlar bazasi (SQLite)
DATABASE_URL="file:./dev.db"

# Sessiya maxfiy kaliti (kamida 32 belgi, tasodifiy)
AUTH_SECRET="change-me-to-a-long-random-string"

# 5sim API kaliti (bo'sh = MOCK/demo rejim)
FIVESIM_API_KEY=""
# 5sim bloklangan bo'lsa — mirror/proxy manzili (aks holda bo'sh qoldiring)
FIVESIM_BASE_URL="https://5sim.net/v1"

# Narx sozlamalari (5sim USD'da qaytaradi)
USD_TO_UZS="12000"
MARKUP_PERCENT="30"

# Ilova manzili (to'lov qaytish havolalari uchun)
APP_URL="http://localhost:3000"

# To'lov / balans to'ldirish
# DEMO to'ldirish sinov uchun darhol balans qo'shadi — PROD'da false qiling!
DEMO_TOPUP="true"
MIN_TOPUP="1000"
MAX_TOPUP="10000000"

# Payme (ixtiyoriy — to'ldirilsa yoqiladi)
PAYME_MERCHANT_ID=""
PAYME_KEY=""

# Click (ixtiyoriy — to'ldirilsa yoqiladi)
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
